NODE_ENV=development
APP_PORT=3001

DATABASE_URL=postgresql://user:password@localhost:5432/jobhunter_ai

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

LOG_LEVEL=info

REDIS_URL=redis://localhost:6379

LINKEDIN_SCRAPER_ENABLED=true
INDEED_SCRAPER_ENABLED=true
ALLJOBS_SCRAPER_ENABLED=true
DRUSHIM_SCRAPER_ENABLED=true
FACEBOOK_GROUP_SCRAPER_ENABLED=false
WELLFOUND_SCRAPER_ENABLED=true
COMPANY_CAREER_PAGE_SCRAPER_ENABLED=false
GOOGLE_JOBS_SCRAPER_ENABLED=false
GLASSDOOR_SCRAPER_ENABLED=false

# SerpAPI — required for Indeed and Google Jobs scraping
# Get your key at https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

ANTHROPIC_API_KEY=sk-ant-your-api-key-here
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

AI_SCORING_ENABLED=true
AI_CV_GENERATION_ENABLED=true
AI_INTERVIEW_PREP_ENABLED=true

LINKEDIN_SESSION_COOKIE=your-li_at-cookie-here
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
BROWSER_POOL_SIZE=3
PROXY_URL=

EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@jobhunter-ai.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

DAILY_SCRAPER_CRON=0 2 * * *
FOLLOW_UP_CHECK_CRON=0 9 * * 1-5

AUTO_APPLY_ENABLED=false
AUTO_APPLY_MIN_SCORE=0.75

APPLICATION_BATCH_SIZE=10
MAX_APPLICATIONS_PER_DAY=20

SENTRY_DSN=
SENTRY_ENABLED=false

FALLBACK_LINKEDIN_PROFILE_VISIBILITY=everyone
FALLBACK_CV_LANGUAGE=english
