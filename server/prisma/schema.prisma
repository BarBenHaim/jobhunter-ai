generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgcrypto]
}

enum JobSource {
  LINKEDIN
  INDEED
  ALLJOBS
  DRUSHIM
  FACEBOOK_GROUP
  WELLFOUND
  COMPANY_CAREER_PAGE
  GOOGLE_JOBS
  GLASSDOOR
  OTHER
}

enum LocationType {
  REMOTE
  HYBRID
  ONSITE
}

enum Recommendation {
  AUTO_APPLY
  MANUAL_REVIEW
  SKIP
  ARCHIVE
}

enum AppStatus {
  PENDING
  CV_GENERATED
  AWAITING_REVIEW
  APPROVED
  APPLIED
  VIEWED
  RESPONDED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum FollowUpType {
  INITIAL
  SECOND
  FINAL
  THANK_YOU
  NEGOTIATION
}

enum ResponseType {
  POSITIVE
  NEGATIVE
  INFO_REQUEST
  INTERVIEW_INVITE
}

model UserProfile {
  id                 String   @id @default(cuid())
  fullName           String
  email              String   @unique
  phone              String?
  location           String?
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  rawKnowledge       Json?    @default("{}")
  structuredProfile  Json?    @default("{}")
  preferences        Json?    @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  personas           Persona[]
  analyticsEvents    AnalyticsEvent[]

  @@map("user_profiles")
}

model Persona {
  id                 String   @id @default(cuid())
  userId             String
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  name               String
  slug               String   @unique
  title              String
  summary            String
  targetKeywords     String[]
  excludeKeywords    String[]
  skillPriority      Json     @default("{}")
  experienceRules    Json     @default("{}")
  cvTemplateId       String?
  isActive           Boolean  @default(true)
  searchSchedule     Json?    @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  applications       Application[]
  scoringRules       ScoringRule[]

  @@unique([userId, slug])
  @@map("personas")
}

model Job {
  id                 String   @id @default(cuid())
  externalId         String?
  source             JobSource
  sourceUrl          String
  title              String
  company            String
  companyUrl         String?
  location           String
  locationType       LocationType
  description        String
  requirements       String?
  salary             Json?    @default("{}")
  experienceLevel    String?
  postedAt           DateTime?
  scrapedAt          DateTime @default(now())
  expiresAt          DateTime?
  isActive           Boolean  @default(true)
  rawData            Json?    @default("{}")
  dedupHash          String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  scores             JobScore[]
  applications       Application[]

  @@index([source])
  @@index([company])
  @@index([isActive])
  @@index([dedupHash])
  @@map("jobs")
}

model JobScore {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  personaId          String

  overallScore       Float
  skillMatch         Float
  experienceMatch    Float
  cultureFit         Float
  salaryMatch        Float
  acceptanceProb     Float
  recommendation     Recommendation
  reasoning          String?
  matchedSkills      String[]
  missingSkills      String[]
  redFlags           String[]
  bestPersonaId      String?
  scoredAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([jobId, personaId])
  @@index([jobId])
  @@index([personaId])
  @@index([overallScore])
  @@map("job_scores")
}

model Application {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  personaId          String
  persona            Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  status             AppStatus @default(PENDING)
  cvFilePath         String?
  coverLetterPath    String?
  cvContent          Json?
  appliedAt          DateTime?
  appliedVia         String?
  responseAt         DateTime?
  responseType       ResponseType?
  interviewDates     DateTime[]
  notes              String?
  score              Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  followUps          FollowUp[]

  @@unique([jobId, personaId])
  @@index([jobId])
  @@index([personaId])
  @@index([status])
  @@map("applications")
}

model FollowUp {
  id                 String   @id @default(cuid())
  applicationId      String
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type               FollowUpType
  scheduledAt        DateTime
  completedAt        DateTime?
  message            String?
  channel            String?
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
  @@map("follow_ups")
}

model AnalyticsEvent {
  id                 String   @id @default(cuid())
  userId             String
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType          String
  entityType         String?
  entityId           String?
  metadata           Json?    @default("{}")
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

model ScoringRule {
  id                 String   @id @default(cuid())
  personaId          String
  persona            Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  ruleType           String
  field              String
  value              String
  weight             Float    @default(1.0)
  learnedFrom        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([personaId])
  @@map("scoring_rules")
}
