generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobSource {
  LINKEDIN
  INDEED
  ALLJOBS
  DRUSHIM
  FACEBOOK_GROUP
  WELLFOUND
  COMPANY_CAREER_PAGE
  GOOGLE_JOBS
  GLASSDOOR
  OTHER
}

enum LocationType {
  REMOTE
  HYBRID
  ONSITE
}

enum Recommendation {
  AUTO_APPLY
  MANUAL_REVIEW
  SKIP
  ARCHIVE
}

enum AppStatus {
  PENDING
  CV_GENERATED
  AWAITING_REVIEW
  APPROVED
  APPLIED
  VIEWED
  RESPONDED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum FollowUpType {
  INITIAL
  SECOND
  FINAL
  THANK_YOU
  NEGOTIATION
}

enum ResponseType {
  POSITIVE
  NEGATIVE
  INFO_REQUEST
  INTERVIEW_INVITE
}

model UserProfile {
  id                    String    @id @default(cuid())
  fullName              String
  email                 String    @unique
  passwordHash          String?
  phone                 String?
  location              String?
  linkedinUrl           String?
  githubUrl             String?
  portfolioUrl          String?
  rawKnowledge          Json?     @default("{}")
  structuredProfile     Json?     @default("{}")
  preferences           Json?     @default("{}")

  // Auth / security fields
  emailVerified         Boolean   @default(false)
  emailVerifyTokenHash  String?
  emailVerifyExpires    DateTime?
  resetTokenHash        String?
  resetTokenExpires     DateTime?
  lastLoginAt           DateTime?
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  tokensValidFrom       DateTime  @default(now())

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  personas              Persona[]
  analyticsEvents       AnalyticsEvent[]
  autopilotRuns         AutoPilotRun[]
  uploadedCVs           UploadedCV[]

  @@map("user_profiles")
}

model Persona {
  id                 String   @id @default(cuid())
  userId             String
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  name               String
  slug               String   @unique
  title              String
  summary            String
  targetKeywords     String[]
  excludeKeywords    String[]
  skillPriority      Json     @default("{}")
  experienceRules    Json     @default("{}")
  cvTemplateId       String?
  isActive           Boolean  @default(true)
  searchSchedule     Json?    @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  applications       Application[]
  scoringRules       ScoringRule[]

  @@unique([userId, slug])
  @@map("personas")
}

model Job {
  id                 String   @id @default(cuid())
  externalId         String?
  source             JobSource
  sourceUrl          String
  title              String
  company            String
  companyUrl         String?
  location           String
  locationType       LocationType
  description        String
  requirements       String?
  salary             Json?    @default("{}")
  experienceLevel    String?
  postedAt           DateTime?
  scrapedAt          DateTime @default(now())
  expiresAt          DateTime?
  isActive           Boolean  @default(true)
  rawData            Json?    @default("{}")
  dedupHash          String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  scores             JobScore[]
  applications       Application[]

  @@index([source])
  @@index([company])
  @@index([isActive])
  @@index([dedupHash])
  @@map("jobs")
}

model JobScore {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  personaId          String

  overallScore       Float
  skillMatch         Float
  experienceMatch    Float
  cultureFit         Float
  salaryMatch        Float
  acceptanceProb     Float
  recommendation     Recommendation
  reasoning          String?
  matchedSkills      String[]
  missingSkills      String[]
  redFlags           String[]
  bestPersonaId      String?
  scoredAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([jobId, personaId])
  @@index([jobId])
  @@index([personaId])
  @@index([overallScore])
  @@map("job_scores")
}

model Application {
  id                 String   @id @default(cuid())
  jobId              String
  job                Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
  personaId          String
  persona            Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  status             AppStatus @default(PENDING)
  autopilotRunId     String?
  cvFilePath         String?
  coverLetterPath    String?
  cvContent          Json?
  appliedAt          DateTime?
  appliedVia         String?
  responseAt         DateTime?
  responseType       ResponseType?
  interviewDates     DateTime[]
  notes              String?
  score              Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  followUps          FollowUp[]

  @@unique([jobId, personaId])
  @@index([jobId])
  @@index([personaId])
  @@index([status])
  @@map("applications")
}

model FollowUp {
  id                 String   @id @default(cuid())
  applicationId      String
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type               FollowUpType
  scheduledAt        DateTime
  completedAt        DateTime?
  message            String?
  channel            String?
  status             String   @default("pending")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([applicationId])
  @@index([status])
  @@map("follow_ups")
}

model AnalyticsEvent {
  id                 String   @id @default(cuid())
  userId             String
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType          String
  entityType         String?
  entityId           String?
  metadata           Json?    @default("{}")
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("analytics_events")
}

enum AutoPilotRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AutoPilotTrigger {
  SCHEDULE
  MANUAL
  WEBHOOK
}

enum AutoPilotLogSeverity {
  INFO
  WARNING
  ERROR
  SUCCESS
}

model AutoPilotRun {
  id                     String              @id @default(cuid())
  userId                 String
  user                   UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId              String?

  status                 AutoPilotRunStatus  @default(RUNNING)
  triggeredBy            AutoPilotTrigger    @default(SCHEDULE)
  config                 Json?               @default("{}")

  jobsDiscovered         Int                 @default(0)
  jobsQualifying         Int                 @default(0)
  cvsGenerated           Int                 @default(0)
  applicationsSubmitted  Int                 @default(0)
  applicationsQueued     Int                 @default(0)
  totalCost              Float               @default(0)
  duration               Int?
  error                  String?

  startedAt              DateTime            @default(now())
  completedAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  logs                   AutoPilotLog[]

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("autopilot_runs")
}

model AutoPilotLog {
  id                     String                 @id @default(cuid())
  runId                  String?
  run                    AutoPilotRun?          @relation(fields: [runId], references: [id], onDelete: Cascade)
  userId                 String

  eventType              String
  message                String
  data                   Json?                  @default("{}")
  severity               AutoPilotLogSeverity   @default(INFO)

  createdAt              DateTime               @default(now())

  @@index([runId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("autopilot_logs")
}

model ScoringRule {
  id                 String   @id @default(cuid())
  personaId          String
  persona            Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  ruleType           String
  field              String
  value              String
  weight             Float    @default(1.0)
  learnedFrom        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([personaId])
  @@map("scoring_rules")
}

enum CVRoleType {
  FRONTEND
  BACKEND
  FULLSTACK
  DEVOPS
  DATA
  MOBILE
  QA
  MANAGEMENT
  GENERAL
}

model UploadedCV {
  id                 String     @id @default(cuid())
  userId             String
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName           String
  filePath           String
  fileSize           Int
  mimeType           String     @default("application/pdf")

  // Role tagging
  roleType           CVRoleType @default(GENERAL)
  roleTypeAutoDetected Boolean  @default(true)
  label              String?    // User-friendly label, e.g. "הCV שלי ל-Frontend"

  // Extracted content
  extractedText      String?    @db.Text
  extractedSkills    String[]
  extractedProfile   Json?      @default("{}")
  parsedAt           DateTime?

  isDefault          Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([userId])
  @@index([userId, roleType])
  @@map("uploaded_cvs")
}

// ─── Hidden/Dismissed Jobs ────────────────────────────────
// User can hide jobs they don't want to see again
model HiddenJob {
  id                 String   @id @default(cuid())
  userId             String
  jobId              String
  reason             String?  // "not_interested", "already_applied", "wrong_fit", etc.
  createdAt          DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@map("hidden_jobs")
}

// ─── Saved Searches ───────────────────────────────────────
// User can save search criteria and get notified about new matches
model SavedSearch {
  id                 String   @id @default(cuid())
  userId             String
  name               String   // User-defined name, e.g. "פולסטאק בסטרטאפים"

  // Search configuration
  freeTextQuery      String?  // Natural language query
  keywords           String[] // Keyword list
  sources            String[] // Job source filters
  location           String?
  minScore           Int      @default(0)
  experienceLevel    String?

  // Notification settings
  notifyEmail        Boolean  @default(true)
  notifyFrequency    String   @default("daily") // "realtime", "hourly", "daily", "weekly"
  isActive           Boolean  @default(true)

  // Tracking
  lastRunAt          DateTime?
  lastNotifiedAt     DateTime?
  totalJobsFound     Int      @default(0)
  newJobsSinceNotify Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([userId, isActive])
  @@map("saved_searches")
}

// ─── Company Profiles ─────────────────────────────────────
// Rich company directory with metadata
model CompanyProfile {
  id                 String   @id @default(cuid())
  slug               String   @unique // URL-friendly identifier
  name               String
  nameHe             String?  // Hebrew name

  // Basic info
  website            String?
  careersUrl         String?
  linkedinUrl        String?
  atsProvider        String?  // "greenhouse", "lever", "ashby", "comeet", "workday", "custom"
  atsIdentifier      String?  // Greenhouse board token, Lever company slug, etc.

  // Company metadata
  foundedYear        Int?
  employeeCount      Int?     // Approximate
  employeeRange      String?  // "1-10", "11-50", "51-200", "201-500", "501-1000", "1001-5000", "5000+"
  industry           String?  // "SaaS", "Fintech", "Cybersecurity", "AI/ML", "HealthTech", etc.
  subIndustry        String?
  techStack          String[] // Known tech stack: ["React", "Python", "AWS", ...]

  // Funding & stage
  stage              String?  // "Seed", "Series A", "Series B", "Series C+", "Public", "Bootstrap"
  lastFundingRound   String?
  lastFundingAmount  String?
  totalFunding       String?

  // Location
  hqCity             String?
  hqCountry          String   @default("Israel")
  offices            String[] // Other office locations

  // Classification
  category           String?  // "unicorn", "top_company", "growing", "startup", "enterprise"
  tags               String[] // Additional tags: "remote-friendly", "defense", "web3", etc.

  // Stats
  activeJobCount     Int      @default(0)
  lastScannedAt      DateTime?

  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([industry])
  @@index([category])
  @@index([hqCountry])
  @@index([isActive])
  @@map("company_profiles")
}
